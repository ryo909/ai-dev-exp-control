{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "STATE.json Schema",
    "description": "AI個人開発実験パイプラインの進捗管理ファイルのスキーマ",
    "type": "object",
    "required": [
        "target_day",
        "next_day",
        "batch_size_default",
        "posts",
        "recent_meta",
        "days",
        "catalog",
        "integrations"
    ],
    "properties": {
        "target_day": {
            "type": "integer",
            "const": 100,
            "description": "目標Day数"
        },
        "next_day": {
            "type": "integer",
            "minimum": 1,
            "maximum": 101,
            "description": "次に生成すべきDay番号"
        },
        "batch_size_default": {
            "type": "integer",
            "const": 7,
            "description": "バッチサイズ（固定）"
        },
        "posts": {
            "type": "object",
            "required": [
                "fixed_tags",
                "templates"
            ],
            "properties": {
                "fixed_tags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "固定ハッシュタグ"
                },
                "templates": {
                    "type": "object",
                    "required": [
                        "standard",
                        "compact",
                        "minimal"
                    ],
                    "properties": {
                        "standard": {
                            "type": "string"
                        },
                        "compact": {
                            "type": "string"
                        },
                        "minimal": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "recent_meta": {
            "type": "array",
            "maxItems": 20,
            "items": {
                "type": "object",
                "required": [
                    "day",
                    "core_action",
                    "twist",
                    "one_sentence"
                ],
                "properties": {
                    "day": {
                        "type": "string"
                    },
                    "core_action": {
                        "type": "string"
                    },
                    "twist": {
                        "type": "string"
                    },
                    "one_sentence": {
                        "type": "string"
                    },
                    "complexity_tier": {
                        "type": "string",
                        "enum": [
                            "small",
                            "medium",
                            "large"
                        ]
                    },
                    "selected_components": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "complexity_prompt_hint": {
                        "type": "string"
                    },
                    "keywords": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            },
            "description": "直近20本のmeta要約（Diversity Gate用）"
        },
        "recent_genres": {
            "type": "array",
            "maxItems": 3,
            "items": {
                "type": "string"
            },
            "description": "直近ジャンル（同ジャンル連続防止用）"
        },
        "theme_mode": {
            "type": "string",
            "enum": [
                "seeded"
            ],
            "description": "テーマ決定モード"
        },
        "days": {
            "type": "object",
            "patternProperties": {
                "^[0-9]{3}$": {
                    "type": "object",
                    "required": [
                        "repo_name",
                        "repo_url",
                        "pages_url",
                        "meta",
                        "post_texts",
                        "status"
                    ],
                    "properties": {
                        "repo_name": {
                            "type": "string"
                        },
                        "repo_url": {
                            "type": "string",
                            "format": "uri"
                        },
                        "pages_url": {
                            "type": "string",
                            "format": "uri"
                        },
                        "meta": {
                            "type": "object",
                            "required": [
                                "core_action",
                                "twist",
                                "one_sentence"
                            ],
                            "properties": {
                                "core_action": {
                                    "type": "string"
                                },
                                "twist": {
                                    "type": "string"
                                },
                                "one_sentence": {
                                    "type": "string"
                                },
                                "complexity_tier": {
                                    "type": "string",
                                    "enum": [
                                        "small",
                                        "medium",
                                        "large"
                                    ]
                                },
                                "selected_components": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                },
                                "complexity_prompt_hint": {
                                    "type": "string"
                                },
                                "original_twist": {
                                    "type": "string"
                                },
                                "original_one_sentence": {
                                    "type": "string"
                                },
                                "enhancement_source": {
                                    "type": "string"
                                },
                                "enhancement_candidate_id": {
                                    "type": "string"
                                },
                                "enhancement_adopted": {
                                    "type": "boolean"
                                },
                                "adopted_next_batch_complexity": {
                                    "type": "boolean"
                                },
                                "adopted_next_batch_components": {
                                    "type": "boolean"
                                },
                                "adopted_next_batch_enhancement": {
                                    "type": "boolean"
                                },
                                "next_batch_plan_source": {
                                    "type": "string"
                                },
                                "next_batch_slot": {
                                    "type": [
                                        "integer",
                                        "null"
                                    ]
                                },
                                "next_batch_recommended_components": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                },
                                "next_batch_recommended_enhancement": {
                                    "type": "boolean"
                                },
                                "genre": {
                                    "type": "string"
                                },
                                "theme": {
                                    "type": "string"
                                },
                                "title": {
                                    "type": "string"
                                },
                                "description": {
                                    "type": "string"
                                },
                                "story_summary": {
                                    "type": "string"
                                },
                                "keywords": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            }
                        },
                        "post_texts": {
                            "type": "object",
                            "required": [
                                "standard",
                                "compact",
                                "minimal"
                            ],
                            "properties": {
                                "standard": {
                                    "type": "string"
                                },
                                "compact": {
                                    "type": "string"
                                },
                                "minimal": {
                                    "type": "string"
                                }
                            }
                        },
                        "status": {
                            "type": "string",
                            "enum": [
                                "pending",
                                "building",
                                "built",
                                "deployed",
                                "posted",
                                "done",
                                "failed"
                            ]
                        }
                    }
                }
            },
            "additionalProperties": false
        },
        "catalog": {
            "type": "object",
            "required": [
                "pages_enabled",
                "catalog_json_path",
                "catalog_html_path"
            ],
            "properties": {
                "pages_enabled": {
                    "type": "boolean"
                },
                "catalog_json_path": {
                    "type": "string"
                },
                "catalog_html_path": {
                    "type": "string"
                }
            }
        },
        "last_run": {
            "type": [
                "string",
                "null"
            ],
            "description": "直近実行日時（ISO 8601）"
        },
        "last_run_at": {
            "type": [
                "string",
                "null"
            ],
            "description": "安全弁用の最終実行日時（ISO 8601）"
        },
        "execution_logs": {
            "type": "array",
            "items": {
                "type": "object"
            },
            "description": "実行ログ"
        },
        "integrations": {
            "type": "object",
            "properties": {
                "buffer_mode": {
                    "type": "string",
                    "enum": [
                        "queue",
                        "disabled"
                    ]
                },
                "make_webhook_env": {
                    "type": "string"
                }
            }
        },
        "notes": {
            "type": "string",
            "description": "任意メモ（障害メモ等）"
        }
    }
}
