{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "meta.json Schema",
  "description": "各Day repoのmeta.jsonスキーマ（品質ゲート用）",
  "type": "object",
  "required": [
    "day",
    "title",
    "description",
    "genre",
    "theme",
    "story_summary",
    "tool_name",
    "core_action",
    "twist",
    "one_sentence"
  ],
  "properties": {
    "day": {
      "type": "string",
      "pattern": "^(Day)?[0-9]{3}$",
      "description": "Day番号（Day001 or 001）"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "表示タイトル"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "1行説明"
    },
    "genre": {
      "type": "string",
      "enum": [
        "productivity",
        "writing",
        "devtools",
        "planning",
        "learning",
        "health",
        "fun"
      ]
    },
    "theme": {
      "type": "string",
      "enum": [
        "NeoLab",
        "Paper",
        "Noir",
        "Brutal",
        "Soft",
        "RetroTerminal",
        "Candy",
        "Mono"
      ]
    },
    "complexity_tier": {
      "type": "string",
      "enum": [
        "small",
        "medium",
        "large"
      ],
      "description": "複雑度ティア"
    },
    "selected_components": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "選択された安全コンポーネント"
    },
    "complexity_prompt_hint": {
      "type": "string",
      "description": "complexity tierに応じた生成ヒント"
    },
    "story_summary": {
      "type": "string",
      "minLength": 1,
      "description": "制作ストーリー1行要約"
    },
    "tool_name": {
      "type": "string",
      "minLength": 1,
      "description": "ツール名"
    },
    "core_action": {
      "type": "string",
      "minLength": 1,
      "description": "何をするか"
    },
    "twist": {
      "type": "string",
      "minLength": 1,
      "description": "差別化ポイント"
    },
    "one_sentence": {
      "type": "string",
      "minLength": 5,
      "description": "1文説明"
    },
    "original_twist": {
      "type": "string",
      "description": "強化採用前のtwist"
    },
    "original_one_sentence": {
      "type": "string",
      "description": "強化採用前のone_sentence"
    },
    "enhancement_source": {
      "type": "string",
      "description": "enhancement候補のソースファイル"
    },
    "enhancement_candidate_id": {
      "type": "string",
      "description": "採用したcandidate id"
    },
    "enhancement_adopted": {
      "type": "boolean",
      "description": "enhancement候補を採用したか"
    },
    "adopted_next_batch_complexity": {
      "type": "boolean"
    },
    "adopted_next_batch_components": {
      "type": "boolean"
    },
    "adopted_next_batch_enhancement": {
      "type": "boolean"
    },
    "next_batch_plan_source": {
      "type": "string"
    },
    "next_batch_slot": {
      "type": [
        "integer",
        "null"
      ]
    },
    "next_batch_recommended_components": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_batch_recommended_enhancement": {
      "type": "boolean"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "repo_name": {
      "type": "string",
      "pattern": "^ai-dev-day-[0-9]{3}$"
    },
    "pages_url": {
      "type": "string",
      "format": "uri"
    }
  }
}
